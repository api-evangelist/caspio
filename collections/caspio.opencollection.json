        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Obtain an OAuth 2.0 access token (client credentials)",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{account}.caspio.com/rest/v3/oauth/token",
            "body": {
              "type": "form-urlencoded",
              "data": [
                {
                  "name": "grant_type",
                  "value": ""
                },
                {
                  "name": "client_id",
                  "value": ""
                },
                {
                  "name": "client_secret",
                  "value": ""
                }
              ]
            }
          },
          "docs": "Obtain an OAuth 2.0 access token (client credentials)"
        }
      ]
    },
