        {
          "info": {
            "name": "Get a table's metadata",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{account}.caspio.com/rest/v3/tables/:tableName",
            "params": [
              {
                "name": "tableName",
